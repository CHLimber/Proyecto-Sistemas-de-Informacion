SECRET_KEY=cambia-esto-en-produccion
JWT_SECRET_KEY=cambia-este-tambien

DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=AWGPMCESE

# Intentos fallidos antes de bloquear (defecto: 3)
LOGIN_MAX_INTENTOS=3

# Correo electrónico (Gmail ejemplo)
# Para Gmail: activar "Contraseñas de aplicación" en la cuenta Google
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_contrasena_de_aplicacion

# --- Railway (no definir en local) ---
# MYSQL_URL=mysql://user:password@host:port/database  <- Railway lo inyecta solo al conectar el plugin MySQL

# --- CORS ---
# En produccion: URL exacta del frontend de Railway (sin slash final)
# ALLOWED_ORIGINS=https://servicontrol-frontend.up.railway.app
# Para multiples origenes separar con coma: ALLOWED_ORIGINS=https://a.com,https://b.com
ALLOWED_ORIGINS=*

# --- Para flask db upgrade en Railway Shell ---
FLASK_APP=wsgi.py
