{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt && python seed_railway.py"
  },
  "deploy": {
    "startCommand": "gunicorn wsgi:app --bind 0.0.0.0:${PORT:-8080} --workers 2 --timeout 120",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
